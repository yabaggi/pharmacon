{
  "name": "pharma-consult",
  "version": "1.0.0",
  "description": "Pharmacist Community Consultation System — Cloudflare Workers + D1",
  "private": true,
  "scripts": {
    "dev":    "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute pharma-consult-db --file=schema.sql",
    "db:init:remote": "wrangler d1 execute pharma-consult-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
